<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atölye OS - Üretim Yönetim Sistemi</title>

    <!-- Font -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #0A0E1A;
            color: #E8EBF0;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        #root {
            width: 100%;
            min-height: 100vh;
        }

        /* Yükleniyor ekranı */
        .loading {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100vh;
            background: linear-gradient(135deg, #0A0E1A 0%, #151927 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

        .loading h1 {
            color: #38BDF8;
            font-family: 'Montserrat', sans-serif;
            font-size: 3rem;
            margin-bottom: 30px;
            text-shadow: 0 0 30px rgba(56, 189, 248, 0.5);
        }

        .loading-spinner {
            width: 60px;
            height: 60px;
            border: 4px solid #2A3040;
            border-top-color: #38BDF8;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .loading-text {
            margin-top: 20px;
            color: #9CA3AF;
            font-size: 1.1rem;
        }

        .error-box {
            background: rgba(248, 113, 113, 0.1);
            border: 1px solid #F87171;
            border-radius: 12px;
            padding: 20px 30px;
            margin-top: 30px;
            max-width: 500px;
            text-align: center;
        }

        .error-box h2 {
            color: #F87171;
            margin-top: 0;
        }
    </style>
</head>
<body>
    <!-- Yükleniyor ekranı -->
    <div id="loading" class="loading">
        <h1>⚙️ Atölye OS</h1>
        <div class="loading-spinner"></div>
        <p class="loading-text">Sistem başlatılıyor...</p>
    </div>

    <!-- React uygulaması buraya yüklenecek -->
    <div id="root"></div>

    <!-- React ve Babel -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

    <!-- Ana uygulama -->
    <script type="text/babel">
        // JSX dosyasını yükle
        fetch('app.jsx')
            .then(response => {
                if (!response.ok) throw new Error('Dosya yüklenemedi');
                return response.text();
            })
            .then(jsxCode => {
                // export default'u kaldır
                const cleanCode = jsxCode.replace('export default function App', 'function App');

                // Babel ile derle
                const compiledCode = Babel.transform(cleanCode, {
                    presets: ['react']
                }).code;

                // Kodu çalıştır
                eval(compiledCode);

                // React uygulamasını başlat
                const root = ReactDOM.createRoot(document.getElementById('root'));
                root.render(React.createElement(App));

                // Yükleme ekranını kaldır
                setTimeout(() => {
                    document.getElementById('loading').style.display = 'none';
                }, 500);
            })
            .catch(error => {
                console.error('Hata:', error);
                document.getElementById('loading').innerHTML = `
                    <div class="error-box">
                        <h2>⚠️ Bağlantı Hatası</h2>
                        <p>Uygulama yüklenirken sorun oluştu.</p>
                        <p style="margin-top:15px">
                            <button onclick="location.reload()" style="
                                background: #38BDF8;
                                color: white;
                                border: none;
                                padding: 10px 20px;
                                border-radius: 8px;
                                cursor: pointer;
                                font-size: 16px;
                            ">Yeniden Dene</button>
                        </p>
                    </div>
                `;
            });
    </script>
</body>
</html>
